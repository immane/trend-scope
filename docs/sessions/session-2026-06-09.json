  "key_decisions": [
    "Backend: FastAPI + SQLAlchemy 2.0 (async) + MySQL 8.0 + Redis 7",
    "Frontend: Next.js 14 App Router + Ant Design 5 + TradingView LWC 5.2",
    "Data: yfinance (primary free) + Finnhub (fallback) + FRED (macro)",
